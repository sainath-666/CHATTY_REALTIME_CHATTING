# Copy to .env and fill in real values (never commit .env).

PORT=5001

# development | production (production serves frontend/dist and uses secure cookies)
NODE_ENV=development

# Strong random string for signing JWTs
JWT_SECRET=

# MongoDB connection string (local or Atlas)
MONGODB_URI=

# Cloudinary — used for profile pictures and image messages
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
